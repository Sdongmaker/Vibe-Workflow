# Optional. Explicit values: openai-compatible, local.
# If empty, the server selects OPENAI_* first, then local fallback.
AI_PROVIDER=

# OpenAI-compatible provider. OPENAI_BASE_URL may include or omit /v1.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your_openai_compatible_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Browser origin allowed by CORS.
CLIENT_ORIGIN=http://localhost:3000

# Local self-hosted uploaded media.
MEDIA_BASE_URL=/media
MEDIA_STORAGE_DIR=./media
LOCAL_WORKFLOW_STORE=./.local_workflows.json

# Optional capability overrides. Accepts JSON, e.g. {"video": false},
# or comma-separated capabilities to force-enable, e.g. text,assets,workflow.
AI_CAPABILITIES=
