# 可选。显式指定后端 AI Provider，可选值：openai-compatible、muapi、local。
# 留空时会自动选择：优先使用 OPENAI_*，其次使用 MU_API_KEY，最后回退到本地模式。
AI_PROVIDER=

# OpenAI 兼容接口配置。OPENAI_BASE_URL 可以带 /v1，也可以不带 /v1。
# API Key 只应放在服务端环境变量中，不要存到浏览器或前端代码里。
# 示例：
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your_openai_compatible_api_key_here
OPENAI_MODEL=gpt-4o-mini

# 旧版 MuAPI 模式。已有 MuAPI 部署可以继续使用，不需要立刻迁移。
MU_API_KEY=your_muapi_api_key_here
MU_API_BASE_URL=https://api.muapi.ai

# 允许跨域访问后端的前端地址。
CLIENT_ORIGIN=http://localhost:3000

# 本地自托管上传文件配置。上传后的文件会通过 MEDIA_BASE_URL 暴露为静态资源。
MEDIA_BASE_URL=/media
MEDIA_STORAGE_DIR=./media
LOCAL_WORKFLOW_STORE=./.local_workflows.json

# 可选能力覆盖。支持 JSON，例如 {"video": false}；
# 也支持逗号分隔的能力列表用于强制开启，例如 text,assets,workflow。
AI_CAPABILITIES=
