# Docker Compose Environment Variables

# Optional. Explicit values: openai-compatible, local.
# If empty, the server selects OPENAI_* first, then local fallback.
AI_PROVIDER=

# OpenAI-compatible provider. OPENAI_BASE_URL may include or omit /v1.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your_openai_compatible_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Frontend and media settings.
API_URL=http://server:8000
CLIENT_ORIGIN=http://localhost:3000
MEDIA_BASE_URL=/media
MEDIA_STORAGE_DIR=/app/media
